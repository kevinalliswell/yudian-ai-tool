  "productName": "宇电 AI 温控工具",
  "version": "0.3.1",
  "identifier": "com.yudian.aitool",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "宇电 AI 温控工具",
        "width": 1180,
        "height": 760,
